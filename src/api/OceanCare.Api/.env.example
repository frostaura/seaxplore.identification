# Never commit production secrets to source control.

# Required: Override the JWT key with a strong random secret (minimum 32 characters)
# Jwt__Key=<your-strong-random-secret-here>

# Connection string for production database
# ConnectionStrings__Default=Data Source=/data/oceancare.db

# Docker Compose sets these automatically via docker-compose.yml environment section.
